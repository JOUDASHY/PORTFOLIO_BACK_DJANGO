# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
BASE_URL=https://portfolio.unityfianar.site
FRONTEND_BASE_URL=http://localhost:5173

# Database Configuration (MySQL)
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=127.0.0.1
DB_PORT=3306

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-backend-domain.com

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# WebAuthn / Face ID Configuration
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Portfolio Nilsen
WEBAUTHN_ORIGIN=http://localhost:5173

# Groq AI Configuration
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Facebook Messenger Configuration
FACEBOOK_PAGE_ACCESS_TOKEN=EAABxxxxxxxxxxxxxxxx
FACEBOOK_VERIFY_TOKEN=THE_BEAST_VERIFY_YOUR_SECURE_TOKEN
FACEBOOK_PAGE_ID=123456789012345
